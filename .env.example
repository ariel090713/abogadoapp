APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3-public
QUEUE_CONNECTION=database

# Mail Configuration
# Local: Gmail SMTP
# Production: AWS SES
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@AbogadoMoapp.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS SES Configuration (for production)
# AWS_SES_REGION=ap-southeast-1
# AWS_SES_CONFIGURATION_SET=

# AWS S3 Configuration
# Public bucket: for profile photos, public documents (world-readable)
# Private bucket: for sensitive documents like IBP cards, legal documents (authenticated access only)
# Note: AWS_PUBLIC_URL and AWS_PRIVATE_URL are optional
# - Leave empty to use default S3 URLs: https://{bucket}.s3.{region}.amazonaws.com
# - Set custom URLs if using CloudFront CDN or custom domains
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_PUBLIC_BUCKET=
AWS_PRIVATE_BUCKET=
AWS_PUBLIC_URL=
AWS_PRIVATE_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
